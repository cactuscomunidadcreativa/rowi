// 📊 BENCHMARK — Motor de Inteligencia Comparativa Viva
// ═══════════════════════════════════════════════════════════════════════════

/// Benchmark principal que contiene toda la data agregada para comparaciones
model Benchmark {
  id             String          @id @default(cuid())
  name           String
  description    String?
  type           BenchmarkType
  status         BenchmarkStatus @default(PROCESSING)

  // Ámbito jerárquico (multinivel)
  scope          BenchmarkScope  @default(GLOBAL)
  tenantId       String?
  hubId          String?
  organizationId String?
  communityId    String?
  teamId         String?

  // Metadata
  sourceFile     String?
  totalRows      Int             @default(0)
  processedRows  Int             @default(0)
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?

  uploadedBy     String
  uploadedAt     DateTime        @default(now())
  processedAt    DateTime?
  lastEnrichedAt DateTime?       // Última vez que se enriqueció con nueva data

  version        Int             @default(1)
  isActive       Boolean         @default(true)
  isLearning     Boolean         @default(true)  // Sigue aprendiendo de nueva data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant       Tenant?       @relation("TenantToBenchmark", fields: [tenantId], references: [id])
  hub          Hub?          @relation("HubToBenchmark", fields: [hubId], references: [id])
  organization Organization? @relation("OrganizationToBenchmark", fields: [organizationId], references: [id])

  dataPoints       BenchmarkDataPoint[]
  statistics       BenchmarkStatistic[]
  correlations     BenchmarkCorrelation[]
  topPerformers    BenchmarkTopPerformer[]
  outcomePatterns  BenchmarkOutcomePattern[]
  userComparisons  BenchmarkUserComparison[]

  @@index([type, scope, isActive])
  @@index([tenantId])
  @@index([hubId])
  @@map("benchmark")
}

enum BenchmarkType {
  ROWIVERSE      // Data global SOH
  EXTERNAL       // Benchmarks de mercado/industria
  INTERNAL       // Benchmarks organizacionales
}

enum BenchmarkScope {
  GLOBAL         // Todo el ecosistema
  REGION         // Por región geográfica
  COUNTRY        // Por país
  SECTOR         // Por industria
  TENANT         // Por organización
  HUB            // Por hub/división
  TEAM           // Por equipo
  COMMUNITY      // Por comunidad
  COHORT         // Por cohorte (edad, rol, etc.)
}

enum BenchmarkStatus {
  PROCESSING
  COMPLETED
  ENRICHING      // Incorporando nueva data
  FAILED
  ARCHIVED
}

/// Data point individual del benchmark (cada registro de la fuente)
model BenchmarkDataPoint {
  id          String   @id @default(cuid())
  benchmarkId String

  // Origen (para learning feedback loop)
  sourceType  String?  // "soh", "rowiverse_user", "tenant_user"
  sourceId    String?  // ID del registro original
  sourceDate  DateTime?

  // Segmentación demográfica
  country     String?
  region      String?
  jobFunction String?
  jobRole     String?
  sector      String?
  ageRange    String?
  gender      String?
  education   String?
  generation  String?  // Millennials, Gen Z, etc.
  year        Int?     // Año del assessment (extraído de Date/Year)
  month       Int?     // Mes del assessment (1-12, extraído de Date)
  quarter     Int?     // Trimestre (1-4, calculado desde month)

  // Segmentación organizacional
  tenantId    String?
  hubId       String?
  teamId      String?
  communityId String?

  // Core EQ (Know/Choose/Give)
  K           Float?
  C           Float?
  G           Float?
  eqTotal     Float?

  // 8 Competencias Six Seconds
  EL          Float?   // Emotional Literacy
  RP          Float?   // Recognize Patterns
  ACT         Float?   // Consequential Thinking
  NE          Float?   // Navigate Emotions
  IM          Float?   // Intrinsic Motivation
  OP          Float?   // Exercise Optimism
  EMP         Float?   // Empathy
  NG          Float?   // Noble Goals

  // Outcomes (lo que buscamos predecir)
  effectiveness    Float?
  relationships    Float?
  qualityOfLife    Float?
  wellbeing        Float?
  influence        Float?
  decisionMaking   Float?
  community        Float?
  network          Float?
  achievement      Float?
  satisfaction     Float?
  balance          Float?
  health           Float?

  // Brain Talents (18 talentos del modelo Six Seconds)
  dataMining       Float?
  modeling         Float?
  prioritizing     Float?
  connection       Float?
  emotionalInsight Float?
  collaboration    Float?
  reflecting       Float?
  adaptability     Float?
  criticalThinking Float?
  resilience       Float?
  riskTolerance    Float?
  imagination      Float?
  proactivity      Float?
  commitment       Float?
  problemSolving   Float?
  vision           Float?
  designing        Float?
  entrepreneurship Float?
  brainAgility     Float?  // Score agregado de agilidad cerebral

  // Profile y otros
  brainStyle       String?
  profile          String?

  // Quality indicators
  reliabilityIndex Float?

  createdAt DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([benchmarkId, country, region])
  @@index([benchmarkId, sector])
  @@index([benchmarkId, tenantId])
  @@index([benchmarkId, jobRole])
  @@map("benchmark_data_point")
}

/// Top Performer — Patrones de los mejores en cada outcome
model BenchmarkTopPerformer {
  id          String   @id @default(cuid())
  benchmarkId String

  // Filtros de contexto
  country     String?
  region      String?
  sector      String?
  jobRole     String?
  ageRange    String?
  tenantId    String?

  // Outcome objetivo (qué queremos lograr)
  outcomeKey  String   // effectiveness, health, relationships, etc.

  // Definición de "top performer"
  percentileThreshold Int @default(90)  // Top 10%
  sampleSize  Int      @default(0)

  // Perfil promedio de los top performers
  avgK        Float?
  avgC        Float?
  avgG        Float?
  avgEL       Float?
  avgRP       Float?
  avgACT      Float?
  avgNE       Float?
  avgIM       Float?
  avgOP       Float?
  avgEMP      Float?
  avgNG       Float?

  // Competencias distintivas (ordenadas por importancia)
  topCompetencies     Json?   // [{key: "OP", avgScore, importance, diffFromAvg}]
  topTalents          Json?   // [{key: "proactivity", avgScore, importance}] - 18 en orden cluster
  topTalentsSummary   Json?   // Top 5 talentos más distintivos

  // Patrones recurrentes
  commonPatterns      Json?   // Combinaciones de competencias que se repiten
  talentPatterns      Json?   // Combinaciones de talentos que se repiten

  // Métricas estadísticas adicionales
  statistics          Json?   // {significantCompetencies, significantTalents, avgEffectSize, globalMeans}
  thresholdValue      Float?  // Valor del umbral P90
  totalPopulation     Int?    // Total de registros
  confidenceLevel     String? // high, medium, low
  lowConfidenceSample Boolean @default(false)
  insufficientReason  String?

  calculatedAt DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, outcomeKey, country, region, sector, jobRole, ageRange, tenantId])
  @@index([benchmarkId, outcomeKey])
  @@map("benchmark_top_performer")
}

/// Correlación — Relación entre competencia y outcome
model BenchmarkCorrelation {
  id            String   @id @default(cuid())
  benchmarkId   String

  // Contexto
  country       String?
  region        String?
  sector        String?
  tenantId      String?
  year          Int?     // Año para comparar evolución temporal

  // Relación
  competencyKey String   // K, C, G, EL, RP, etc.
  outcomeKey    String   // effectiveness, health, etc.

  // Estadísticas
  correlation   Float    // Pearson r (-1 a 1)
  pValue        Float?   // Significancia estadística
  n             Int      @default(0)

  // Interpretación
  strength      String?  // strong, moderate, weak
  direction     String?  // positive, negative

  calculatedAt  DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, competencyKey, outcomeKey, country, region, sector, tenantId, year])
  @@index([benchmarkId, outcomeKey])
  @@index([benchmarkId, year])
  @@map("benchmark_correlation")
}

/// Outcome Pattern — Mapas de éxito emocional
model BenchmarkOutcomePattern {
  id          String   @id @default(cuid())
  benchmarkId String

  outcomeKey  String   // El outcome que queremos lograr

  // Contexto
  country     String?
  region      String?
  sector      String?
  tenantId    String?

  // El patrón descubierto
  patternName        String?   // "El Optimista Empático", etc.
  patternDescription String?

  // Competencias clave (en orden de importancia)
  keyCompetencies    Json      // [{key, weight, minThreshold}]
  keyTalents         Json?     // [{key, weight}]

  // Métricas
  sampleSize         Int       @default(0)
  avgOutcomeScore    Float?
  successRate        Float?    // % que logran alto outcome con este patrón

  confidence         Float?    // Confianza estadística

  calculatedAt DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([benchmarkId, outcomeKey])
  @@map("benchmark_outcome_pattern")
}

/// Estadísticas — Pre-calculadas por filtros
model BenchmarkStatistic {
  id          String   @id @default(cuid())
  benchmarkId String

  // Filtros
  country     String?
  region      String?
  sector      String?
  jobRole     String?
  ageRange    String?
  gender      String?
  education   String?
  tenantId    String?

  // Métrica
  metricKey   String

  // Estadísticas
  n           Int      @default(0)
  mean        Float?
  median      Float?
  stdDev      Float?
  min         Float?
  max         Float?
  p10         Float?
  p25         Float?
  p50         Float?
  p75         Float?
  p90         Float?
  p95         Float?

  calculatedAt DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, metricKey, country, region, sector, jobRole, ageRange, gender, education, tenantId])
  @@index([benchmarkId, metricKey])
  @@map("benchmark_statistic")
}

/// User Comparison — Comparación individual guardada
model BenchmarkUserComparison {
  id          String   @id @default(cuid())
  benchmarkId String
  userId      String?
  memberId    String?

  // Outcome buscado
  targetOutcome String  // effectiveness, health, etc.

  // Contexto usado para comparar
  comparisonContext Json  // {country, region, sector, etc.}
  fallbackUsed      String? // null, "region", "global"

  // Fortalezas del usuario (lo que YA tiene)
  userStrengths     Json    // [{competency, score, percentile, vsTopPerformer}]

  // Cómo los top performers usan fortalezas similares
  topPerformerInsights Json  // [{strength, howTheyUseIt, resultTheyGet}]

  // Qué desarrollar (apalancado en fortalezas)
  developmentAreas  Json    // [{area, priority, leveragedBy, actionSuggestion}]

  // Puntajes comparativos
  userScores        Json
  benchmarkScores   Json
  percentiles       Json

  // Resumen generado
  summaryInsight    String?

  createdAt DateTime @default(now())

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([memberId])
  @@map("benchmark_user_comparison")
}

/// Upload Job — Procesamiento de archivos (con soporte para Cron)
model BenchmarkUploadJob {
  id           String    @id @default(cuid())
  benchmarkId  String?

  status       String    @default("pending")  // pending, processing, completed, failed
  progress     Int       @default(0)
  currentPhase String?

  // Para procesamiento con Cron
  blobUrl      String?                        // URL del archivo en Vercel Blob
  currentRow   Int       @default(0)          // Fila actual para continuar procesamiento

  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  failedRows    Int      @default(0)

  errorMessage String?
  errorDetails Json?

  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@map("benchmark_upload_job")
}

/// 🌐 RowiVerse Contribution — Registro de cada contribución de data EQ al benchmark global
model RowiVerseContribution {
  id          String   @id @default(cuid())

  // Quién contribuyó
  userId      String?  // Usuario de Rowi (si aplica)
  memberId    String?  // CommunityMember (si es data de CSV)
  tenantId    String?  // Tenant de origen

  // A qué benchmark se contribuyó
  benchmarkId String   // El benchmark ROWIVERSE global
  dataPointId String?  // El BenchmarkDataPoint creado

  // Tipo de contribución
  sourceType  String   // "registration", "csv_upload", "eq_snapshot", "manual"
  sourceId    String?  // ID del registro fuente (EqSnapshot, CsvUpload, etc.)

  // Datos contribuidos (anonimizados)
  eqTotal     Float?
  K           Float?
  C           Float?
  G           Float?

  // Demographics (anonimizados)
  country     String?
  region      String?
  sector      String?
  jobFunction String?
  ageRange    String?
  gender      String?

  // Estado
  status      String   @default("pending")  // pending, processed, rejected
  processedAt DateTime?

  createdAt   DateTime @default(now())

  @@index([benchmarkId])
  @@index([userId])
  @@index([memberId])
  @@index([tenantId])
  @@index([status])
  @@map("rowiverse_contribution")
}

// =========================================================
// 💳 STRIPE & PAGOS
// =========================================================

/// 💳 Suscripción de usuario con Stripe
model Subscription {
  id          String   @id @default(cuid())
  userId      String
  planId      String

  // Stripe IDs
  stripeSubscriptionId String  @unique
  stripePriceId        String
  stripeCustomerId     String

  // Estado
  status       SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  cancelledAt        DateTime?

  // Trial
  trialStart DateTime?
  trialEnd   DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscription")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

/// 💰 Historial de pagos
model Payment {
  id          String   @id @default(cuid())
  userId      String

  // Stripe IDs
  stripePaymentIntentId String? @unique
  stripeInvoiceId       String? @unique
  stripeChargeId        String?

  // Detalles
  amountCents  Int
  currency     String   @default("usd")
  status       PaymentStatus @default(PENDING)
  description  String?

  // Metadata
  metadata     Json?
  receiptUrl   String?
  invoiceUrl   String?

  paidAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@map("payment")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

/// 🎁 Cupones y descuentos
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String?  // Nombre descriptivo del cupón

  // Tipo de descuento
  discountType    CouponType @default(PERCENTAGE)
  discountValue   Float      // Porcentaje o monto fijo

  // Categoría de cupón
  category        CouponCategory @default(GENERAL)

  // Restricciones
  maxUses         Int?       // Usos máximos totales
  usedCount       Int        @default(0)
  maxUsesPerUser  Int        @default(1)
  minAmountCents  Int?       // Monto mínimo para aplicar

  // Planes válidos (null = todos)
  validPlanIds    String[]   @default([])

  // Vigencia
  startsAt        DateTime   @default(now())
  expiresAt       DateTime?

  // Estado
  active          Boolean    @default(true)

  // Código personalizado para usuarios específicos
  targetUserId    String?    // Si es personalizado para un usuario
  targetEmail     String?    // Email del destinatario (para envío)
  sentAt          DateTime?  // Cuándo se envió el código

  // Gamificación
  achievementId   String?    // ID del logro que desbloquea este cupón
  isGamificationReward Boolean @default(false)

  // Notas internas
  notes           String?

  // Stripe
  stripeCouponId  String?    @unique

  // Creador del cupón
  createdBy       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions CouponRedemption[]

  @@map("coupon")
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_TRIAL_DAYS
  FREE_ACCESS      // Acceso gratuito completo
}

enum CouponCategory {
  GENERAL          // Cupón general
  PROMOTIONAL      // Promoción de marketing
  PERSONAL         // Código personalizado para un usuario
  GAMIFICATION     // Premio por logro/gamificación
  REFERRAL         // Código de referido
  PARTNER          // Código de partner/aliado
}

/// 🎟️ Redención de cupones
model CouponRedemption {
  id       String   @id @default(cuid())
  couponId String
  userId   String

  // Contexto
  subscriptionId String?
  paymentId      String?

  // Valores aplicados
  discountApplied Float

  redeemedAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_redemption")
}

// =========================================================
// 🧠 SIX SECONDS INTEGRATION
// =========================================================

/// 📤 Cola de solicitudes SEI pendientes
model SeiRequest {
  id          String   @id @default(cuid())
  userId      String

  // Datos del usuario para Six Seconds
  email       String
  name        String
  country     String?
  language    String   @default("es")

  // Link directo al SEI (proporcionado por Six Seconds)
  seiLink     String?              // Link para tomar el SEI directamente

  // Estado
  status      SeiRequestStatus @default(PENDING)

  // Six Seconds
  sixSecondsProjectId String?     // Proyecto en Six Seconds donde se envió
  sixSecondsEmail     String?     // Email enviado por Six Seconds

  // Tracking
  requestedAt  DateTime @default(now())
  sentAt       DateTime?           // Cuando se envió a Six Seconds (manual)
  startedAt    DateTime?           // Cuando el usuario empezó el SEI
  completedAt  DateTime?           // Cuando se recibió el resultado
  expiresAt    DateTime?           // Fecha límite para completar

  // Resultado (cuando se importa)
  resultSnapshotId String?         // EqSnapshot creado con el resultado

  // Notas admin
  adminNotes   String?
  processedBy  String?             // Email del admin que procesó

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([email])
  @@map("sei_request")
}

enum SeiRequestStatus {
  PENDING          // Esperando envío a Six Seconds
  SENT             // Enviado a Six Seconds (link enviado al usuario)
  IN_PROGRESS      // Usuario está completando el SEI
  COMPLETED        // SEI completado, resultados recibidos
  EXPIRED          // Expiró sin completar
  CANCELLED        // Cancelado por el usuario o admin
}

/// 📥 Importación de CSV de Six Seconds
model SixSecondsImport {
  id          String   @id @default(cuid())

  // Archivo
  filename    String
  fileSize    Int

  // Procesamiento
  status      SixSecondsImportStatus @default(PENDING)
  totalRows   Int      @default(0)
  processedRows Int    @default(0)
  matchedUsers  Int    @default(0)   // Usuarios encontrados en Rowi
  newSnapshots  Int    @default(0)   // EqSnapshots creados
  activatedUsers Int   @default(0)   // Usuarios activados (PENDING_SEI -> ACTIVE)

  // Errores
  failedRows  Int      @default(0)
  errors      Json?                   // Array de errores detallados

  // Admin
  uploadedBy  String                  // Email del admin
  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@map("six_seconds_import")
}

enum SixSecondsImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL       // Completado con algunos errores
}

/// 🔗 Links SEI por idioma (configurables desde CMS)
model SeiLink {
  id          String   @id @default(cuid())

  // Identificador único para el link
  code        String   @unique    // "default", "es-basic", "en-pro", etc.
  name        String              // Nombre descriptivo para el CMS

  // Link al SEI
  url         String              // URL completa del SEI en Six Seconds

  // Configuración
  language    String   @default("es")  // Idioma del SEI
  planSlug    String?                   // Plan asociado (null = todos)
  isDefault   Boolean  @default(false) // Link por defecto para el idioma

  // Tracking Six Seconds
  sixSecondsProjectId String?     // ID del proyecto en Six Seconds

  // Estado
  isActive    Boolean  @default(true)

  // Meta
  description String?             // Descripción interna
  notes       String?             // Notas para admins

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([language])
  @@index([isActive])
  @@map("sei_link")
}

/// 📝 Contenido CMS editable (textos de onboarding, páginas, etc.)
model CmsContent {
  id          String   @id @default(cuid())

  // Identificador único del contenido
  key         String              // "onboarding.welcome.title", "onboarding.step1.description"
  language    String   @default("es")

  // Contenido
  value       String   @db.Text    // El texto/HTML
  valueType   CmsValueType @default(TEXT)  // TEXT, HTML, MARKDOWN, JSON

  // Categoría para organizar
  category    String?             // "onboarding", "pricing", "landing", etc.
  subcategory String?             // "step1", "step2", etc.

  // Metadata
  description String?             // Descripción para el admin
  placeholder String?             // Valor por defecto si está vacío

  // Estado
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, language])
  @@index([category])
  @@index([language])
  @@map("cms_content")
}

enum CmsValueType {
  TEXT
  HTML
  MARKDOWN
  JSON
}

/// 🎨 Configuración de onboarding (pasos, colores, etc.)
model OnboardingConfig {
  id          String   @id @default(cuid())

  // Configuración general
  key         String   @unique     // "general", "steps", "features", etc.
  config      Json                 // Configuración JSON

  // Estado
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_config")
}

// =========================================================
// 📊 VENTAS Y FINANZAS
// =========================================================

/// 📈 Registro de conversiones y fuentes de adquisición
model UserAcquisition {
  id          String   @id @default(cuid())
  userId      String   @unique

  // Fuente de adquisición
  source      AcquisitionSource @default(ORGANIC)
  channel     String?           // "google", "facebook", "referral", etc.
  campaign    String?           // Campaña específica
  medium      String?           // "cpc", "email", "social", etc.

  // Referido
  referredBy  String?           // userId del referente
  referralCode String?          // Código de referido usado

  // Cupón usado en registro
  couponCode  String?

  // UTM params
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Landing page
  landingPage String?

  // Conversiones
  registeredAt DateTime @default(now())
  convertedAt  DateTime?          // Cuando se convirtió a pago

  // Valor
  lifetimeValueCents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([referredBy])
  @@map("user_acquisition")
}

enum AcquisitionSource {
  ORGANIC
  PAID_SEARCH
  PAID_SOCIAL
  REFERRAL
  EMAIL
  DIRECT
  AFFILIATE
  PARTNER
  EVENT
  OTHER
}

/// 💵 Comisiones de referidos
model ReferralCommission {
  id          String   @id @default(cuid())

  // Quién refirió
  referrerId  String

  // Quién fue referido
  referredUserId String

  // Pago que generó la comisión
  paymentId   String?

  // Comisión
  commissionCents Int
  commissionRate  Float           // Porcentaje de comisión (ej: 0.20 = 20%)

  // Estado
  status      CommissionStatus @default(PENDING)

  // Pago de la comisión
  paidAt      DateTime?
  payoutId    String?           // Referencia al pago

  createdAt DateTime @default(now())

  @@index([referrerId])
  @@index([status])
  @@map("referral_commission")
}

enum CommissionStatus {
  PENDING     // Esperando que pase el período de reembolso
  APPROVED    // Aprobada, lista para pago
  PAID        // Pagada
  CANCELLED   // Cancelada (ej: reembolso del referido)
}

/// 📊 Métricas de ventas agregadas (por día/mes)
model SalesMetric {
  id          String   @id @default(cuid())

  // Período
  date        DateTime @db.Date
  period      MetricPeriod @default(DAILY)

  // Métricas de usuarios
  newUsers           Int @default(0)
  newTrials          Int @default(0)
  trialConversions   Int @default(0)
  churned            Int @default(0)

  // Métricas de ingresos (en centavos)
  mrrCents           Int @default(0)   // Monthly Recurring Revenue
  newMrrCents        Int @default(0)   // MRR de nuevos clientes
  expansionMrrCents  Int @default(0)   // MRR de upgrades
  churnedMrrCents    Int @default(0)   // MRR perdido por churn

  // Métricas de pagos
  totalPayments      Int @default(0)
  totalRevenueCents  Int @default(0)
  refundsCents       Int @default(0)

  // SEI
  seiRequests        Int @default(0)
  seiCompleted       Int @default(0)

  createdAt DateTime @default(now())

  @@unique([date, period])
  @@index([date])
  @@map("sales_metric")
}

enum MetricPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

/// =========================================================
/// 🎨 LANDING PAGE BUILDER — Secciones visuales de la landing
/// =========================================================
/// Sistema de CMS visual estilo Elementor para construir la landing page.
/// Cada sección tiene un tipo, orden, configuración visual y contenido traducible.

model LandingSection {
  id          String   @id @default(cuid())
  
  // Tipo de sección (hero, features, testimonials, pricing, etc.)
  type        LandingSectionType
  
  // Orden en la página (0, 1, 2...)
  order       Int      @default(0)
  
  // Visibilidad
  isVisible   Boolean  @default(true)
  
  // Configuración visual (colores, espaciado, animaciones, etc.)
  config      Json?    // { bgColor, padding, animation, columns, etc. }
  
  // Contenido por idioma { es: {...}, en: {...} }
  content     Json     // Estructura depende del tipo
  
  // Metadatos
  name        String?  // Nombre interno para el admin
  description String?  // Descripción interna
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([order])
  @@index([type])
  @@map("landing_section")
}

enum LandingSectionType {
  NAVBAR
  HERO
  FEATURES
  HOW_IT_WORKS
  TESTIMONIALS
  PRICING
  CTA
  STATS
  FAQ
  LOGOS
  FOOTER
  CUSTOM
  EVOLUTION
  WORLD_MAP
}

/// 🖼️ Media Library para el Landing Builder
model LandingMedia {
  id          String   @id @default(cuid())

  // URL del archivo (puede ser local o CDN)
  url         String

  // Tipo de media
  type        String   @default("image") // image, video, icon

  // Metadatos
  name        String
  alt         String?
  width       Int?
  height      Int?
  size        Int?     // bytes

  // Etiquetas para organizar
  tags        String[] @default([])

  createdAt   DateTime @default(now())

  @@map("landing_media")
}

// ============================================
// 🎮 GAMIFICACIÓN
// ============================================

/// 🏆 Definición de logros/achievements disponibles
model Achievement {
  id          String   @id @default(cuid())

  // Identificador único del logro (ej: "first_chat", "eq_master")
  slug        String   @unique

  // Información del logro
  name        String                    // Nombre en español
  nameEN      String?                   // Nombre en inglés
  description String                    // Descripción en español
  descriptionEN String?                 // Descripción en inglés

  // Visual
  icon        String?                   // Nombre del icono (lucide) o URL
  color       String   @default("#8B5CF6") // Color del badge

  // Categoría
  category    AchievementCategory @default(GENERAL)

  // Requisitos
  requirement AchievementRequirement    // Tipo de requisito
  threshold   Int      @default(1)      // Cantidad requerida

  // Puntos que otorga
  points      Int      @default(10)

  // Nivel de dificultad/rareza
  rarity      AchievementRarity @default(COMMON)

  // Estado
  isActive    Boolean  @default(true)

  // Orden de display
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  userAchievements UserAchievement[]

  @@map("achievements")
}

/// 🎖️ Logros obtenidos por usuarios (unificado con AvatarMilestone)
model UserAchievement {
  id            String   @id @default(cuid())

  userId        String
  achievementId String
  avatarId      String?                   // 🔗 Opcional: vinculo con avatar (antes AvatarMilestone)

  // Progreso (para logros graduales)
  progress      Int      @default(0)      // Progreso actual
  completed     Boolean  @default(false)  // ¿Completado?
  completedAt   DateTime?                 // Fecha de completado

  // Campos migrados de AvatarMilestone
  xpReward      Int      @default(0)      // XP otorgado (para logros de avatar)
  metadata      Json?                     // Metadata adicional

  // Notificación
  notified      Boolean  @default(false)  // ¿Ya se notificó al usuario?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement      @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  avatar        AvatarEvolution? @relation("AvatarAchievements", fields: [avatarId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([avatarId])
  @@map("user_achievements")
}

/// 💰 Puntos del usuario (historial)
model UserPoints {
  id          String   @id @default(cuid())

  userId      String

  // Puntos
  amount      Int                        // Cantidad de puntos (+/-)
  balance     Int                        // Balance después de esta transacción

  // Razón
  reason      PointsReason               // Tipo de transacción
  reasonId    String?                    // ID relacionado (achievementId, etc.)
  description String?                    // Descripción adicional

  createdAt   DateTime @default(now())

  // Relaciones
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_points")
}

/// 🔥 Rachas de actividad (streaks)
model UserStreak {
  id          String   @id @default(cuid())

  userId      String   @unique

  // Racha actual
  currentStreak Int    @default(0)       // Días consecutivos actuales
  longestStreak Int    @default(0)       // Racha más larga histórica

  // Control de racha
  lastActivityDate DateTime?             // Última fecha de actividad
  streakStartDate  DateTime?             // Inicio de la racha actual

  // Bonus por racha
  multiplier    Float  @default(1.0)     // Multiplicador de puntos por racha

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

/// 📊 Nivel del usuario
model UserLevel {
  id          String   @id @default(cuid())

  userId      String   @unique

  // Nivel actual
  level       Int      @default(1)

  // Puntos totales acumulados
  totalPoints Int      @default(0)

  // Puntos para el siguiente nivel
  pointsToNextLevel Int @default(100)

  // Título del nivel
  title       String?                    // Ej: "Explorador Emocional"
  titleEN     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_levels")
}

// Enums de gamificación
enum AchievementCategory {
