  output    String // Respuesta esperada
  meta      Json? // Datos adicionales o tags
  createdAt DateTime    @default(now())
  agent     AgentConfig @relation("AgentConfigToTrainingSample", fields: [agentId], references: [id], onDelete: Cascade)

