/// =========================================================
/// ⚙️ AFFINITY CONFIG — Configuración por scope jerárquico
/// =========================================================
/// Permite configurar el motor de Affinity a diferentes niveles:
/// global → tenant → hub → organization → team
/// La configuración más específica tiene prioridad (cascada inversa)
model AffinityConfig {
  id        String   @id @default(cuid())
  scope     String   // "global" | "tenant" | "hub" | "organization" | "team"
  scopeId   String?  // ID del scope (null si es global)

  // Pesos por contexto (JSON con growth, collab, understand para cada contexto)
  contextWeights Json @default("{}")

  // Parámetros de aprendizaje automático
  learningParams Json @default("{}")

  // Umbrales de banda (hot, warm, cold)
  bandThresholds Json @default("{}")

  // Multiplicadores de cercanía (cercano, neutral, lejano)
  closenessMultipliers Json @default("{}")

  // Metadata
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  // Relaciones opcionales para integridad referencial
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String?
  hub          Hub?          @relation(fields: [hubId], references: [id], onDelete: Cascade)
  hubId        String?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?

  @@unique([scope, scopeId])
  @@index([scope])
  @@index([tenantId])
  @@index([hubId])
  @@index([organizationId])
  @@map("affinity_config")
}

/// =========================================================
/// 🏢 AI CULTURE CONFIG — Contexto cultural para agentes IA
/// =========================================================
/// Configuración jerárquica del contexto cultural que los
/// agentes IA usarán para adaptar su comunicación.
/// Herencia: team → organization → hub → tenant → global
model AiCultureConfig {
  id        String   @id @default(cuid())
  scope     String   // "global" | "tenant" | "hub" | "organization" | "team"
  scopeId   String?  // ID del scope (null si es global)

  // Identidad organizacional
  mission   String?  // Misión de la organización
  vision    String?  // Visión de la organización
  values    Json     @default("[]") // Array de valores corporativos
  industry  String?  // Industria/sector

  // Comunicación
  tone      String   @default("professional") // Tono: professional, friendly, casual, formal, inspirational
  language  String   @default("es") // Idioma preferido
  keywords  Json     @default("[]") // Palabras clave/terminología específica

  // Directrices para agentes
  guidelines   String? // Lo que los agentes DEBEN hacer
  restrictions String? // Lo que los agentes NO deben hacer

  // Metadata
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  // Relaciones opcionales
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String?
  hub          Hub?          @relation(fields: [hubId], references: [id], onDelete: Cascade)
  hubId        String?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?

  @@unique([scope, scopeId])
  @@index([scope])
  @@index([tenantId])
  @@index([hubId])
  @@index([organizationId])
  @@map("ai_culture_config")
}

