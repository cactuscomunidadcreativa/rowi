/// =========================================================
/// 🧾 ACTIVITY LOG — Registro unificado de acciones y auditoría
/// =========================================================
/// Unifica ActivityLog y AuditLog en un solo modelo.
/// - userId: quien ejecuta la acción (opcional para acciones del sistema)
/// - targetUserId: usuario afectado por la acción (opcional)
model ActivityLog {
  id           String   @id @default(cuid())
  userId       String?                      // Actor (opcional para acciones del sistema)
  targetUserId String?                      // Usuario objetivo (migrado de AuditLog.targetId)
  action       String                       // Tipo de acción
  entity       String?                      // Entidad afectada (User, Tenant, etc.)
  targetId     String?                      // ID de la entidad afectada
  details      Json?                        // Detalles adicionales (antes: meta en AuditLog)
  ipAddress    String?                      // IP del actor (para auditoría)
  userAgent    String?                      // User agent (para auditoría)
  createdAt    DateTime @default(now())

  // Relaciones
  user         User?    @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("ActivityLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([targetUserId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_log")
}

model RoleDynamic {
