  SEVEN_DAY_STREAK      // Racha de 7 días
  THIRTY_DAY_STREAK     // Racha de 30 días
  AFFINITY_ANALYSIS     // Análisis de afinidad
  FIRST_REFLECTION      // Primera reflexión
  FIRST_DECISION        // Primera decisión
